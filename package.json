{
  "name": "gpt-repo-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Read-mostly MCP server for controlled ChatGPT access to approved local repositories with opt-in safe file and git operations.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redxzeta/gpt-repo-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/redxzeta/gpt-repo-mcp/issues"
  },
  "homepage": "https://github.com/redxzeta/gpt-repo-mcp#readme",
  "keywords": [
    "mcp",
    "chatgpt",
    "developer-tools",
    "repository",
    "local-first"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server.js",
  "bin": {
    "gpt-repo": "dist/cli/connect-gpt.js",
    "connect-gpt": "dist/cli/connect-gpt.js"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "mcp": "GPT_REPO_CONFIG=./config.local.json PORT=8787 npm run dev",
    "tunnel": "ngrok http 8787 --log=stdout",
    "connect": "node scripts/connect-dev.mjs",
    "connect:secure": "node scripts/connect-secure.mjs",
    "add": "node dist/cli/connect-gpt.js add",
    "remove": "node dist/cli/connect-gpt.js remove",
    "list": "node dist/cli/connect-gpt.js list",
    "check:config": "node dist/cli/connect-gpt.js check",
    "doctor": "npm run build && node dist/cli/connect-gpt.js doctor",
    "build": "tsup src/server.ts --format esm --dts --clean && tsup src/cli/connect-gpt.ts --format esm --out-dir dist/cli",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check:public": "node scripts/check-public.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "ignore": "^7.0.5",
    "zod": "^4.1.12"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.14"
  }
}
